# Copy this file to deploy/alibaba/env.alibaba on the Alibaba ECS instance.
# Never commit deploy/alibaba/env.alibaba.

DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
VEXA_FORCE_MOCK=1
VEXA_HOST=0.0.0.0
VEXA_API_PORT=8080
VEXA_SANDBOX_ORIGIN=http://<ecs-public-ip>:8080
