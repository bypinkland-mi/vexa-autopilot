{
  "name": "vexa-autopilot",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Public-safe Qwen Cloud hackathon demo for an approval-safe browser agent.",
  "license": "MIT",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:api": "node server/index.mjs",
    "start": "node server/index.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "qa:browser": "node scripts/qa-playwright.mjs",
    "check:public": "node scripts/public-safety-check.mjs",
    "check:submission": "npm test && npm run build && npm run check:public",
    "demo:mock": "VEXA_FORCE_MOCK=1 node server/index.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.6.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "openai": "^5.8.2",
    "playwright": "^1.61.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "vitest": "^3.2.4"
  }
}
