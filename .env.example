# Copy to .env.local for local experiments. Never commit real keys.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
VEXA_FORCE_MOCK=1
VEXA_HOST=127.0.0.1
VEXA_API_PORT=8798
VEXA_API_TARGET=http://127.0.0.1:8798
VEXA_SANDBOX_ORIGIN=http://127.0.0.1:8798
# Leave empty in production so the frontend uses same-origin /api.
VITE_VEXA_API_BASE_URL=

# Local Qwen planner, e.g. LM Studio OpenAI-compatible server.
# Start LM Studio local server first, then set:
# VEXA_PLANNER_PROVIDER=local-qwen
# LOCAL_QWEN_BASE_URL=http://127.0.0.1:1234/v1
# LOCAL_QWEN_MODEL=prism-qwen35-9b-v2
